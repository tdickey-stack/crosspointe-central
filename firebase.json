      {
        "source": "/wayfinder-chat.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store"
          }
        ]
      },
      {
        "source": "/favicon.svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/terms",
        "destination": "/terms.html"
      },
      {
        "source": "/terms/",
        "destination": "/terms.html"
      },
      {
        "source": "/privacy",
        "destination": "/privacy.html"
      },
      {
        "source": "/privacy/",
        "destination": "/privacy.html"
      },
