{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "lint": "eslint .",
    "test:wayfinder": "node --test planning-center/*.test.js wayfinder/*.test.js",
    "wayfinder:validate": "node scripts/validate-wayfinder-knowledge.mjs",
    "wayfinder:query": "node scripts/query-wayfinder-knowledge.mjs",
    "wayfinder:import:dry-run": "node scripts/import-wayfinder-knowledge.mjs --dry-run",
    "wayfinder:import:emulator": "node scripts/import-wayfinder-knowledge.mjs --emulator-host=127.0.0.1:8080 --project=crosspointe-central",
    "wayfinder:pco-check": "node --env-file-if-exists=.env --env-file-if-exists=.secret.local scripts/check-wayfinder-planning-center.mjs",
    "studio:image": "node --env-file-if-exists=.env --env-file-if-exists=.secret.local scripts/generate-studio-image.mjs",
    "studio:refine": "node --env-file-if-exists=.env --env-file-if-exists=.secret.local scripts/refine-studio-image.mjs",
    "test:studio": "node --test studio/*.test.js",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "type": "module",
  "main": "index.js",
  "dependencies": {
    "@google/genai": "^2.11.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.4.1"
  },
  "private": true
}
