rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Bulletin images are written only by the permission-checked Admin API.
    // The generated Firebase download token is used by the print renderer.
    match /bulletin-mode/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
